class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int tempCount=0;
        int maxCount=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]==1){
                tempCount++;
            }
            else{
                maxCount=Math.max(maxCount,tempCount);
                tempCount=0;
            }
        }
        return Math.max(maxCount,tempCount);
    }
}