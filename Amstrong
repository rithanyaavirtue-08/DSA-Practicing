class Solution {
    static boolean armstrongNumber(int n) {

       int original=n;
       int sum=0;

       int temp=n;
       int digitCount=0;
       while(temp>0){
           digitCount++;
           temp=temp/10;
       }
        temp=n;
       while(temp>0){
           int digit=temp%10;
           sum+=Math.pow(digit,digitCount);
           temp=temp/10;
       }
       if(sum==original){
           return true;
       }
       else {
           return false;
       }
    }
}
